@PACKAGE_INIT@

# 传递声明对 Qt6 的依赖，确保下游 find_package(QtQuickComponents) 时
# Qt6::Quick 和 Qt6::QuickControls2 目标已就绪。
include(CMakeFindDependencyMacro)
find_dependency(Qt6 REQUIRED COMPONENTS Quick QuickControls2)

include("${CMAKE_CURRENT_LIST_DIR}/QtQuickComponentsTargets.cmake")
check_required_components(QtQuickComponents)
